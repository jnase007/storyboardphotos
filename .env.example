# Supabase Environment Variables
# Copy to .env.local and fill in values from your Supabase / Vercel dashboard

# Public (safe for browser) — either naming style works
NEXT_PUBLIC_SUPABASE_URL=https://cpnnztrqgbxledbikpqt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Short aliases also supported:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Server-only (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Image Generation (at least one required for real images)
GOOGLE_AI_API_KEY=your-google-ai-api-key
REPLICATE_API_TOKEN=your-replicate-api-token
TOGETHER_API_KEY=your-together-api-key

# Storybook Generator (names from your Vercel setup)
FAL_API_KEY=your-fal-ai-key
GROK_API_KEY=your-grok-xai-key
# Also accepted: FAL_KEY, XAI_API_KEY, ANTHROPIC_API_KEY

# Site URL (for metadata)
NEXT_PUBLIC_SITE_URL=https://www.storybookphotos.com
